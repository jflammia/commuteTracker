# Receiver configuration
RECEIVER_HOST=0.0.0.0
RECEIVER_PORT=8080

# Raw data storage path (local disk, fast writes)
RAW_DATA_DIR=./raw

# S3-compatible backup storage (optional but recommended)
S3_ENDPOINT_URL=http://minio.local:9000
S3_BUCKET=commute-tracker-raw
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_SYNC_INTERVAL_SECONDS=300

# Home location (lat, lon, radius in meters)
HOME_LAT=0.0
HOME_LON=0.0
HOME_RADIUS_M=150

# Work location (lat, lon, radius in meters)
WORK_LAT=0.0
WORK_LON=0.0
WORK_RADIUS_M=150
