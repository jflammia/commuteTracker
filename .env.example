# Receiver configuration
RECEIVER_HOST=0.0.0.0
RECEIVER_PORT=8080

# Database (SQLite default, PostgreSQL supported)
# For Docker: use absolute path with 4 slashes: sqlite:////data/commute_tracker.db
# For local dev: relative path with 3 slashes: sqlite:///data/commute_tracker.db
DATABASE_URL=sqlite:////data/commute_tracker.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/commute_tracker

# Derived data directory (processed Parquet files)
# For Docker: /data/derived
# For local dev: leave empty to use PROJECT_ROOT/derived
# DERIVED_DATA_DIR=/data/derived

# S3-compatible backup storage (optional but recommended)
# When configured, enables JSONL export and local DB pruning
S3_ENDPOINT_URL=
S3_BUCKET=commute-tracker-raw
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_SYNC_INTERVAL_SECONDS=300

# Local data retention (only applies when S3 is configured)
# Rows confirmed synced to S3 and older than this are pruned from the database
# Set to 0 to disable pruning (keep everything locally)
LOCAL_RETENTION_DAYS=90

# OwnTracks Recorder passthrough (optional, off by default)
# Set to forward all payloads to an OwnTracks Recorder instance
RECORDER_URL=
# RECORDER_URL=http://recorder:8083/pub

# Home location (lat, lon, radius in meters)
HOME_LAT=0.0
HOME_LON=0.0
HOME_RADIUS_M=50

# Work location (lat, lon, radius in meters)
WORK_LAT=0.0
WORK_LON=0.0
WORK_RADIUS_M=150
